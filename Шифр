<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ШДЧС — Шифровальщик</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
    .output { font-family: 'Courier New', monospace; letter-spacing: 2px; }
  </style>
</head>
<body class="bg-gradient-to-br from-zinc-950 via-slate-900 to-indigo-950 text-white min-h-screen">

  <div class="max-w-3xl mx-auto p-6 pt-12">
    <div class="text-center mb-10">
      <h1 class="text-6xl font-black mb-2 bg-gradient-to-r from-cyan-400 via-purple-500 to-pink-500 bg-clip-text text-transparent">
        🔐 ШДЧС
      </h1>
      <p class="text-2xl text-slate-300">Шифрование Число-Символы</p>
    </div>

    <div class="bg-zinc-900/80 backdrop-blur-2xl rounded-3xl shadow-2xl border border-slate-700 overflow-hidden">
      
      <div class="flex border-b border-slate-700">
        <button onclick="switchTab(0)" class="tab-btn flex-1 py-5 text-lg font-semibold border-b-4 border-cyan-500 text-cyan-400">Зашифровать</button>
        <button onclick="switchTab(1)" class="tab-btn flex-1 py-5 text-lg font-semibold">Расшифровать</button>
      </div>

      <!-- Зашифровать -->
      <div id="tab0" class="p-8">
        <textarea id="plainText" rows="5" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-6 text-lg focus:outline-none focus:border-cyan-400 resize-y" placeholder="Введите текст..."></textarea>
        
        <div class="grid grid-cols-2 gap-6 mt-6">
          <div>
            <label class="block text-slate-400 mb-2 text-sm">Год</label>
            <input type="number" id="encYear" value="2026" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-5 text-xl">
          </div>
          <div>
            <label class="block text-slate-400 mb-2 text-sm">Месяц</label>
            <input type="number" id="encMonth" value="5" min="1" max="12" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-5 text-xl">
          </div>
        </div>

        <button onclick="encrypt()" class="w-full mt-8 bg-gradient-to-r from-cyan-500 to-purple-600 hover:from-cyan-600 hover:to-purple-700 py-6 rounded-3xl text-2xl font-bold transition-all active:scale-95">
          🔒 Зашифровать текст
        </button>

        <div id="encResult" class="mt-8 hidden">
          <div class="flex justify-between items-center mb-3">
            <p class="text-slate-400">Результат:</p>
            <button onclick="copyResult('encOutput')" class="text-cyan-400 hover:text-cyan-300 text-sm flex items-center gap-2">
              <i class="fas fa-copy"></i> Копировать
            </button>
          </div>
          <div id="encOutput" class="output bg-zinc-950 border border-slate-600 rounded-3xl p-6 text-lg break-all min-h-[100px]"></div>
        </div>
      </div>

      <!-- Расшифровать -->
      <div id="tab1" class="p-8 hidden">
        <textarea id="cipherText" rows="5" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-6 text-lg focus:outline-none focus:border-cyan-400 resize-y" placeholder="Вставьте зашифрованный текст..."></textarea>
        
        <div class="flex gap-4 mt-8">
          <button onclick="decryptAuto()" class="flex-1 bg-gradient-to-r from-emerald-500 to-teal-600 py-6 rounded-3xl text-xl font-bold">
            🔍 Автоподбор
          </button>
          <button onclick="showManualDecrypt()" class="flex-1 bg-zinc-700 hover:bg-zinc-600 py-6 rounded-3xl text-xl font-bold">
            Вручную
          </button>
        </div>

        <div id="manualPanel" class="hidden grid grid-cols-2 gap-6 mt-6">
          <div>
            <label class="block text-slate-400 mb-2">Год</label>
            <input type="number" id="decYear" value="2026" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-5">
          </div>
          <div>
            <label class="block text-slate-400 mb-2">Месяц</label>
            <input type="number" id="decMonth" value="5" min="1" max="12" class="w-full bg-zinc-950 border border-slate-600 rounded-2xl p-5">
          </div>
          <button onclick="decryptManual()" class="col-span-2 mt-4 bg-slate-700 hover:bg-slate-600 py-5 rounded-3xl">Расшифровать</button>
        </div>

        <div id="decResult" class="mt-8 hidden">
          <div class="flex justify-between items-center mb-3">
            <p class="text-slate-400">Расшифровано:</p>
            <button onclick="copyResult('decOutput')" class="text-cyan-400 hover:text-cyan-300 text-sm flex items-center gap-2">
              <i class="fas fa-copy"></i> Копировать
            </button>
          </div>
          <div id="decOutput" class="output bg-zinc-950 border border-slate-600 rounded-3xl p-6 text-lg"></div>
        </div>
      </div>
    </div>

    <div class="text-center mt-10 text-slate-500">
      <button onclick="showInfo()" class="underline hover:text-slate-300">Таблицы и кодовые слова →</button>
    </div>
  </div>

  <!-- Модальное окно -->
  <div id="modal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4">
    <div class="bg-zinc-900 rounded-3xl max-w-2xl w-full max-h-[90vh] overflow-auto">
      <div class="p-8" id="modalBody"></div>
      <div class="p-6 border-t border-slate-700 text-center">
        <button onclick="closeModal()" class="px-10 py-4 bg-slate-700 hover:bg-slate-600 rounded-2xl">Закрыть</button>
      </div>
    </div>
  </div>

  <script>
    // Таблицы
    const EVEN = {1:["кафе",1],2:["кофе",2],3:["жюри",3],4:["заяц",4],5:["юг",5],6:["счёт",6],7:["заря",1],8:["арбуз",2],9:["дом",3],10:["кот",4],11:["мак",5],12:["рак",6]};
    const ODD = {1:["рак",1],2:["мор",2],3:["мир",3],4:["час",4],5:["юла",5],6:["ель",6],7:["ива",1],8:["око",2],9:["миг",3],10:["мел",4],11:["лов",5],12:["зов",6]};

    let SYMBOL_TO_NUM = {}, NUM_TO_SYMBOL = {}, DIGIT_TO_SYMBOL = {'0':'Q','1':'!','2':'@','3':'D','4':'$','5':'|','6':'?','7':'&','8':'*','9':'\\'};
    let SYMBOL_TO_DIGIT = {};

    function init() {
      "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯ".split('').forEach((c,i)=> SYMBOL_TO_NUM[c]=i+1);
      "абвгдеёжзийклмнопрстуфхцчшщъыьэюя".split('').forEach((c,i)=> SYMBOL_TO_NUM[c]=i+34);
      SYMBOL_TO_NUM[' '] = 67; SYMBOL_TO_NUM['.']=68; SYMBOL_TO_NUM[',']=69;
      SYMBOL_TO_NUM['!']=70; SYMBOL_TO_NUM['?']=71; SYMBOL_TO_NUM['-']=72;
      SYMBOL_TO_NUM[';']=73; SYMBOL_TO_NUM[':']=74; SYMBOL_TO_NUM['(']=75;
      SYMBOL_TO_NUM[')']=76; SYMBOL_TO_NUM['"']=77; SYMBOL_TO_NUM['\n']=78;

      NUM_TO_SYMBOL = Object.fromEntries(Object.entries(SYMBOL_TO_NUM).map(a=>[a[1],a[0]]));
      SYMBOL_TO_DIGIT = Object.fromEntries(Object.entries(DIGIT_TO_SYMBOL).map(a=>[a[1],a[0]]));
    }

    function getCode(year, month) {
      return (year % 2 === 0 ? EVEN : ODD)[month] || ["",0];
    }

    function encrypt() {
      const text = document.getElementById('plainText').value;
      const year = +document.getElementById('encYear').value;
      const month = +document.getElementById('encMonth').value;
      
      let nums = text.split('').map(c => SYMBOL_TO_NUM[c] || 0);
      let [, add] = getCode(year, month);
      let shifted = nums.map(n => n + add);
      
      let result = '';
      for (let n of shifted) {
        let s = n.toString().padStart(2,'0');
        for (let d of s) result += DIGIT_TO_SYMBOL[d];
      }
      result += getCode(year, month)[0].toUpperCase();

      document.getElementById('encOutput').textContent = result;
      document.getElementById('encResult').classList.remove('hidden');
    }

    function decryptAuto() {
      const cipher = document.getElementById('cipherText').value.trim();
      document.getElementById('decOutput').innerHTML = '<span class="text-slate-400">Идёт поиск...</span>';
      document.getElementById('decResult').classList.remove('hidden');

      for (let y=2020; y<=2035; y++) {
        for (let m=1; m<=12; m++) {
          const res = decrypt(cipher, y, m);
          if (res && !res.includes('Ошибка')) {
            document.getElementById('decOutput').innerHTML = `<strong class="text-emerald-400">✅ Успешно!</strong><br>Год: ${y} | Месяц: ${m}<br><br>${res}`;
            return;
          }
        }
      }
      document.getElementById('decOutput').textContent = "Не удалось автоматически подобрать параметры";
    }

    function decrypt(cipher, year, month) {
      let text = cipher.trim();
      const [word, add] = getCode(year, month);
      if (!word) return "Ошибка";

      if (!text.toUpperCase().endsWith(word.toUpperCase())) return "Кодовое слово не найдено";

      let part = text.slice(0, -word.length);
      if (part.length % 2 !== 0) return "Ошибка длины";

      let digits = '';
      for (let c of part) digits += SYMBOL_TO_DIGIT[c] || '';

      let nums = [];
      for (let i=0; i<digits.length; i+=2) nums.push(+digits.slice(i,i+2));

      return nums.map(n => NUM_TO_SYMBOL[n - add] || '?').join('');
    }

    function decryptManual() {
      const cipher = document.getElementById('cipherText').value;
      const year = +document.getElementById('decYear').value;
      const month = +document.getElementById('decMonth').value;
      const res = decrypt(cipher, year, month);
      document.getElementById('decOutput').textContent = res;
      document.getElementById('decResult').classList.remove('hidden');
    }

    function showManualDecrypt() {
      document.getElementById('manualPanel').classList.toggle('hidden');
    }

    function copyResult(id) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text).then(() => {
        alert("Скопировано в буфер обмена!");
      });
    }

    function switchTab(n) {
      document.getElementById('tab0').classList.add('hidden');
      document.getElementById('tab1').classList.add('hidden');
      document.getElementById(`tab${n}`).classList.remove('hidden');
    }

    function showInfo() {
      let html = `<h2 class="text-3xl font-bold mb-8 text-center">Кодовые слова</h2>`;
      html += `<div class="grid grid-cols-2 gap-10">`;
      html += `<div><h3 class="text-cyan-400 mb-4">ЧЁТНЫЙ ГОД</h3>`;
      for(let m=1;m<=12;m++){ let [w,a]=EVEN[m]||["",0]; html+=`<div class="flex justify-between py-1"><span>${m}</span><span>${w}</span><span>+${a}</span></div>`; }
      html += `</div><div><h3 class="text-purple-400 mb-4">НЕЧЁТНЫЙ ГОД</h3>`;
      for(let m=1;m<=12;m++){ let [w,a]=ODD[m]||["",0]; html+=`<div class="flex justify-between py-1"><span>${m}</span><span>${w}</span><span>+${a}</span></div>`; }
      html += `</div></div>`;
      document.getElementById('modalBody').innerHTML = html;
      document.getElementById('modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
    }

    // Запуск
    init();
    switchTab(0);
  </script>
</body>
</html>
